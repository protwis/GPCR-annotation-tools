      "struct": {
        "title": "Cryo-EM structure of MT3-Muscarinic acetylcholine receptor 4"
      },
      "rcsb_ma_qa_metric_global": null,
      "rcsb_primary_citation": {
        "id": "primary",
        "pdbx_database_id_DOI": "10.1038/s41467-025-61695-0"
